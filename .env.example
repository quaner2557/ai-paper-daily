# 大模型 API 配置（必填）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 双模型配置（推荐）
# 粗排：使用 Flash（便宜快速，适合大规模筛选）
LLM_PRERANK_MODEL=qwen-flash
# 精排：使用 Plus（效果好，适合深入分析）
LLM_FINERANK_MODEL=qwen-plus

# arXiv 配置（推荐系统 + 机器学习 + AI + NLP）
ARXIV_CATEGORIES=cs.IR,cs.LG,cs.AI,cs.CL
MAX_PAPERS_FETCH=300
MAX_PAPERS_OUTPUT=20

# 评分阈值（粗排阈值：≥4 分通过）
MIN_RELEVANCE_SCORE=4

# 飞书推送配置（可选，支持多个 URL 用逗号分隔）
FEISHU_URL=

# 钉钉推送配置（可选，支持多个 URL 用逗号分隔）
# 如果有加签，需要同时配置 DINGTALK_SECRET
DINGTALK_URL=
DINGTALK_SECRET=
